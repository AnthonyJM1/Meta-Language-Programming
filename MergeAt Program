fun mergeAt (A, B, i) =
    case (A, i) of
        (_, 0) => B @ A
      | ([], _) => B
      | (x :: xs, i) => x :: mergeAt (xs, B, i - 1);
mergeAt ([1,2,3,4], [9,9], 2);
(* [1,2,9,9,3,4] *)

mergeAt ([1,2,3], [4,5], 3);
(* [1,2,3,4,5] *)

mergeAt ([1,2,3], [4,5], 1);
(* [1,4,5,2,3] *)

mergeAt ([], [4,5], 2);
(* [4,5] *)

